---
/**
 * IdeaRenderer Component
 * Renders an idea entry using the shared nibzard feed-card system.
 */
import { render } from 'astro:content';

interface Props {
  entry: any;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id.split('/').pop().replace('.md', '');
---

<article
  class="idea-card"
  data-href={`/idea/${slug}`}
  role="button"
  tabIndex="0"
  aria-label={`Read idea: ${entry.data.title}`}
>
  <div class="entry-meta">
    <time datetime={entry.data.date.toISOString()}>
      {new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
    {entry.data.category && <span class="entry-type">Idea</span>}
  </div>

  <div class="idea-content">
    <p class="idea-category">{entry.data.category || 'Idea'}</p>
    <h2 class="idea-title">{entry.data.title}</h2>
    {entry.data.subtitle && <p class="idea-subtitle">{entry.data.subtitle}</p>}
    <div class="idea-description">
      <Content />
    </div>
  </div>
</article>
